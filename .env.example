# ─────────────────────────────────────────────────────────────
# SEMAH AI Brand Studio — Environment variables template
# ─────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in your values:
#   cp .env.example .env
#
# NEVER commit real secrets. This file is documentation only.
# ─────────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────────
# Local dev (SQLite):
DATABASE_URL="file:./db/custom.db"
# Production (PostgreSQL on Railway):
# DATABASE_URL="postgresql://user:pass@host:5432/db?schema=public"

# ── Auth (NextAuth.js v4) ───────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="generate-with: openssl rand -base64 32"
# Public URL of the app (used for callback URLs, cookies, etc.)
NEXTAUTH_URL="http://localhost:3000"

# ── Google OAuth (optional) ─────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# ── Z.ai SDK (AI assistant) ─────────────────────────────────
# The z-ai-web-dev-sdk reads its key from the environment automatically.
# ZAI_API_KEY=""

# ── Stripe billing (future) ─────────────────────────────────
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# STRIPE_PRICE_STARTER=""
# STRIPE_PRICE_PRO=""
# STRIPE_PRICE_BUSINESS=""

# ── Resend email (future) ───────────────────────────────────
# RESEND_API_KEY=""
# FROM_EMAIL=""

# ── App ─────────────────────────────────────────────────────
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
